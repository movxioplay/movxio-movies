# MOVXIO — Cloudflare Pages _redirects

# ── Static page aliases ────────────────────────────────────────
/home    /index.html    301
/movies  /browse.html   301

# ── Bare /film → browse ────────────────────────────────────────
/film    /browse.html   302

# ── Clean film URL — worker handles actual slug routing,
#    this 200 rewrite is a fallback so Pages doesn't 404.
/film/*  /watch.html   200
